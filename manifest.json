{
  "manifest_version": 3,
  "name": "Scroll Companion",
  "version": "1.0",
  "description": "Interrupts doomscrolling with awareness prompts",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}